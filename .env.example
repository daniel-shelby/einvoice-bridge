# Copy to .env and fill in. The .env file itself is gitignored.

# --- Bridge ---
DATABASE_URL=sqlite:./data/invoices.db
BIND_ADDR=127.0.0.1:8080
RUST_LOG=einvoice_bridge=info,einvoice_adapters=info,tower_http=info

# Set LHDN_OFFLINE=true to run the HTTP API only and skip loading the
# .p12 + OAuth credentials. The submitter worker is not spawned in this
# mode, so invoices stay in `Pending` until you flip back to live mode.
# Use this in dev when you don't yet have preprod creds.
LHDN_OFFLINE=false

# --- LHDN MyInvois ---
# 'preprod' against https://preprod-api.myinvois.hasil.gov.my
# 'prod'    against https://api.myinvois.hasil.gov.my
LHDN_ENV=preprod
LHDN_CLIENT_ID=
LHDN_CLIENT_SECRET=
LHDN_TIN=
LHDN_BRN=

# --- Signing certificate ---
LHDN_P12_PATH=./secrets/cert.p12
LHDN_P12_PASSWORD=
